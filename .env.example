# Prompt Engineering Challenge - Environment Configuration
# Copy this file to .env and add your API keys

# Google Gemini API Key (Recommended for image comparison scoring)
# Get your free API key from: https://aistudio.google.com/app/apikey
# Without this, the tool will use random scoring for similarity comparison
GOOGLE_API_KEY=your_google_api_key_here

# Hugging Face API Token (Required for real AI image generation)
# Get your free token from: https://huggingface.co/settings/tokens
# Without this, the tool will generate placeholder images with your prompt text
HUGGINGFACE_TOKEN=hf_your_token_here

# Alternative image generation APIs (not yet implemented)
# REPLICATE_API_TOKEN=your_replicate_token_here
# OPENAI_API_KEY=your_openai_key_here
